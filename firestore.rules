rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'staff';
    }

    function isStudent() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'student';
    }

    function isStudentVerified() {
      return isStudent()
        && exists(/databases/$(database)/documents/students/$(getUserData(request.auth.uid).studentId))
        && get(/databases/$(database)/documents/students/$(getUserData(request.auth.uid).studentId)).data.lastLoggedInUid == request.auth.uid;
    }

    // --- Student Credentials (Managed by Staff) ---
    match /students/{studentId} {
      // Allow any signed in user to query/get students to verify login
      allow read: if isSignedIn(); 
      
      // Allow updating last login info if the user knows the registerNo and password (verified via query in app)
      allow update: if isStaff() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoggedInUid', 'lastLoginAt']));
      
      allow create, delete: if isStaff();
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isStaff();
      allow create: if isOwner(userId)
        && (
          (request.resource.data.role == 'staff' && request.resource.data.keys().hasAll(['uid', 'name', 'role'])) ||
          (request.resource.data.role == 'student' && request.resource.data.keys().hasAll(['uid', 'name', 'role', 'studentId']) && get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data.lastLoggedInUid == request.auth.uid)
        )
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'department', 'studentId', 'lastAttendanceAt']);
      allow delete: if isStaff() && resource.data.role == 'student';
    }

    // --- Classes ---
    match /classes/{classId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['name', 'code', 'staffId'])
        && request.resource.data.staffId == request.auth.uid;
      allow update: if isStaff() && resource.data.staffId == request.auth.uid;
      allow delete: if isStaff() && resource.data.staffId == request.auth.uid;
    }

    // --- Sessions ---
    match /sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['classId', 'staffId', 'qrCodeData', 'status', 'startTime', 'expiryTime'])
        && request.resource.data.staffId == request.auth.uid;
      allow update: if isStaff() && resource.data.staffId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'endTime']);
      allow delete: if isStaff() && resource.data.staffId == request.auth.uid;
    }

    // --- Attendance ---
    match /attendance/{recordId} {
      // Students can only see their own attendance
      // Staff can see all attendance
      allow get: if isSignedIn() && (isStaff() || resource.data.studentId == getUserData(request.auth.uid).studentId);
      allow list: if isSignedIn() && (isStaff() || (isStudent() && resource.data.studentId == getUserData(request.auth.uid).studentId));

      allow create: if (isStudentVerified()
        && request.resource.data.studentId == getUserData(request.auth.uid).studentId
        && getAfter(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.status == 'active')
        || isStaff();
      
      // Attendance records are generally immutable once created (for students)
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    // --- Student Percentages ---
    match /studentPercentages/{id} {
      allow read: if isSignedIn();
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['registerNo', 'name', 'percentage', 'staffId', 'createdAt'])
        && request.resource.data.staffId == request.auth.uid;
      allow delete: if isStaff() && resource.data.staffId == request.auth.uid;
    }
  }
}
