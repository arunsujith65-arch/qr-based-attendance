rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'staff';
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin';
    }

    function isStudent() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'student';
    }

    function isStudentVerified() {
      return isStudent()
        && exists(/databases/$(database)/documents/students/$(getUserData(request.auth.uid).staffId + '_' + getUserData(request.auth.uid).studentId))
        && get(/databases/$(database)/documents/students/$(getUserData(request.auth.uid).staffId + '_' + getUserData(request.auth.uid).studentId)).data.lastLoggedInUid == request.auth.uid;
    }

    function isStaffVerified() {
      return isStaff()
        && exists(/databases/$(database)/documents/staff_registrations/$(getUserData(request.auth.uid).staffId))
        && get(/databases/$(database)/documents/staff_registrations/$(getUserData(request.auth.uid).staffId)).data.lastLoggedInUid == request.auth.uid;
    }

    // --- Staff Registrations (Managed by Admin) ---
    match /staff_registrations/{id} {
      allow list: if isSignedIn() && (isAdmin() || isStaff());
      allow get: if isSignedIn();
      allow update: if (isAdmin()) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoggedInUid', 'lastLoginAt']));
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['staffId', 'instanceId', 'name', 'password', 'createdAt']);
      allow delete: if isAdmin();
    }

    // --- Student Credentials (Managed by Staff) ---
    match /students/{studentId} {
      // Allow any signed in user to get students to verify login
      allow get: if isSignedIn(); 
      // Allow listing students managed by staff or for admin
      allow list: if isSignedIn() && (isAdmin() || (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId));
      
      // Allow updating last login info if the user is authorized
      allow update: if (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoggedInUid', 'lastLoginAt']));
      
      allow create: if isStaff() 
        && request.resource.data.staffId == getUserData(request.auth.uid).staffId
        && request.resource.data.keys().hasAll(['registerNo', 'instanceId', 'name', 'password', 'staffId', 'createdAt']);
      allow delete: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isStaff() || isAdmin());
      allow create: if isOwner(userId)
        && (
          (request.resource.data.role == 'admin') ||
          (request.resource.data.role == 'staff' && exists(/databases/$(database)/documents/staff_registrations/$(request.resource.data.staffId))) ||
          (request.resource.data.role == 'student' && exists(/databases/$(database)/documents/students/$(request.resource.data.staffId + '_' + request.resource.data.studentId)))
        )
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId)
        && (
          isAdmin() || 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'role', 'department', 'studentId', 'staffId', 'instanceId', 'lastAttendanceAt'])
        );
      allow delete: if isAdmin();
    }

    // --- Classes ---
    match /classes/{classId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId) ||
        (isStudent() && resource.data.staffId == getUserData(request.auth.uid).staffId)
      );
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['name', 'code', 'staffId', 'instanceId', 'createdAt'])
        && request.resource.data.staffId == getUserData(request.auth.uid).staffId
        && request.resource.data.instanceId == getUserData(request.auth.uid).instanceId;
      allow update: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
      allow delete: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
    }

    // --- Sessions ---
    match /sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId) ||
        (isStudent() && resource.data.staffId == getUserData(request.auth.uid).staffId)
      );
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['classId', 'staffId', 'instanceId', 'qrCodeData', 'status', 'startTime', 'expiryTime'])
        && request.resource.data.staffId == getUserData(request.auth.uid).staffId
        && request.resource.data.instanceId == getUserData(request.auth.uid).instanceId;
      allow update: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'endTime']);
      allow delete: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
    }

    // --- Attendance ---
    match /attendance/{recordId} {
      // Students can only see their own attendance
      // Staff can only see attendance for their own sessions
      allow get: if isSignedIn() && (
        (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId) || 
        (isStudent() && resource.data.studentId == getUserData(request.auth.uid).studentId)
      );
      allow list: if isSignedIn() && (
        (isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId) || 
        (isStudent() && resource.data.studentId == getUserData(request.auth.uid).studentId && resource.data.staffId == getUserData(request.auth.uid).staffId)
      );

      allow create: if (isStudentVerified()
        && request.resource.data.studentId == getUserData(request.auth.uid).studentId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'present'
        && request.resource.data.instanceId == getUserData(request.auth.uid).instanceId
        && request.resource.data.timestamp == request.time
        && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.status == 'active'
        && request.resource.data.classId == get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.classId
        && request.resource.data.staffId == get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.staffId
        && request.resource.data.staffId == getUserData(request.auth.uid).staffId)
        || (isStaff() 
            && request.resource.data.staffId == getUserData(request.auth.uid).staffId
            && request.resource.data.instanceId == getUserData(request.auth.uid).instanceId
            && (request.resource.data.status == 'present' || request.resource.data.status == 'absent')
            && request.resource.data.timestamp == request.time);
      
      allow update: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
      allow delete: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
    }
    // --- Student Percentages ---
    match /studentPercentages/{id} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isStaff() || isStudent()) && resource.data.staffId == getUserData(request.auth.uid).staffId;
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['registerNo', 'name', 'percentage', 'staffId', 'instanceId', 'createdAt'])
        && request.resource.data.staffId == getUserData(request.auth.uid).staffId
        && request.resource.data.instanceId == getUserData(request.auth.uid).instanceId;
      allow delete: if isStaff() && resource.data.staffId == getUserData(request.auth.uid).staffId;
    }
  }
}
